 "},{"a":184,"m":"obj_tatefuda","c":"obj_tatefuda","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0,0],"s":0.008,"p":[-2.528,2.5,-0.892],"txt":"OBSERVATION PLATFORM\nPress  to switch \nto first-person view \nand take a look around.\nDon't miss anything!"},{"a":184,"m":"obj_tatefuda","c":"obj_tatefuda","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0,0],"s":0.008,"p":[-2.763,2.5,-0.087],"ry":-90,"txt":"Climbing's easy! When you\njump at trees, poles, or\npillars, you'll grab them\nautomatically. \nIn Standard Mode:\nPress the  Up or \nDown to climb.\nCrouch to stop climbing.\n\n\nTo rotate around the \nobject, press Right or \nLeft on the .\n\n\nLeap toward the\ncharacter's back to jump\noff in that direction.\n\n\nWhen you reach the top,\npress Up on the  to\ndo a handstand! Jump off\nfrom the handstand for a\nhigh, stylin' dismount."},{"a":164,"m":"battan","c":"battan","cm":[0.07056,-0.0708,0,0.07324,0.07324,0,0,0,0.09985,0,-0.01856,0],"s":0.008,"p":[-1.535,2.5,-1.207]},{"a":164,"m":"battan","c":"battan","cm":[0.07056,-0.0708,0,0.07324,0.07324,0,0,0,0.09985,0,-0.01856,0],"s":0.008,"p":[0.2,2.5,-1.8],"ry":-141.998},{"a":250,"m":"pakkun_model","s":0.008,"p":[4.5,0.25,4.913]},{"a":250,"m":"pakkun_model","s":0.008,"p":[1.779,2.5,-0.114]},{"a":250,"m":"pakkun_model","s":0.008,"p":[0.748,2.5,1.754]},{"a":29,"m":"obj_updnlift","c":"obj_updnlift","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0.24,-0.15],"s":0.008,"p":[0.95,2.63,-0.85],"ry":45},{"a":287,"p":[-2.5,2.5,-0.256]},{"a":287,"p":[-2.437,1.3,-0.25]},{"a":161,"m":"dosune","c":"dosune","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0,0],"s":0.008,"p":[3.35,1.05,-3.2],"ry":90},{"a":161,"m":"dosune","c":"dosune","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0,0],"s":0.008,"p":[3.325,1.893,-1.48],"ry":-180},{"a":207,"m":"houdai","s":0.008,"p":[-1.8,1,3.8],"ry":90},{"a":20,"m":"hatena_karabox","s":0.008,"p":[2.6,1.299,-3.2]},{"a":10,"m":"b_coin_switch","c":"b_coin_switch","cm":[0.09985,0,0,0,0.09985,0,0,0,0.09985,0,0,0],"s":0.008,"p"