.DS_Store
site/dist/

# --- copyrighted game images: never committed (each game's writeup pins its MD5) ---
games/*/image/
games/*/*.tap
games/*/*.adf
games/*/*.nds
games/*/*.gb
games/*/*.gg
games/*/*.bin
games/*/*.cue
games/*/*.prg
games/*/*.rom
games/*/*.iso
games/*/*.img
games/*/*.z64
games/*/*.v64
games/*/*.n64
games/*/*.cso
games/*/*.cci
# Ultima Underworld installed game tree (copyrighted commercial data)
games/ultima-underworld-pc/game/

# --- compiled binaries from `go build` in a cmd/ or extract dir (no extension) ---
# A stray binary is any extensionless file dropped at a module root by `go build`.
# Everything legitimately tracked at these roots is a directory, go.mod/go.sum, or *.go,
# so ignore the rest and re-include those.
games/*/extract/*
!games/*/extract/*/
!games/*/extract/*.go
!games/*/extract/go.mod
!games/*/extract/go.sum
games/*/extract/cmd/*/*[!.go]
# tools module: command binaries stray at the tools root (source is in tools/cmd/<name>/)
/tools/*
!/tools/*/
!/tools/*.go
!/tools/go.mod
!/tools/go.sum

# --- regenerable extraction output (dev-only) ---
games/*/extracted/
games/*/work/
games/*/extract/unpacked/
games/*/extract/decode
games/*/extract/unpack
games/*/extract/runlauncher
