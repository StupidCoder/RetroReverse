.DS_Store
site/dist/

# --- copyrighted game images: never committed (each game's writeup pins its MD5) ---
games/*/image/
games/*/*.tap
games/*/*.adf
games/*/*.nds
games/*/*.gb
games/*/*.gg
games/*/*.bin
games/*/*.cue
games/*/*.prg
games/*/*.rom
games/*/*.iso
games/*/*.img
# Ultima Underworld installed game tree (copyrighted commercial data)
games/ultima-underworld-pc/game/

# --- compiled binaries from `go build` in a cmd/ or extract dir (no extension) ---
games/*/extract/extract
games/*/extract/cmd/*/*[!.go]
games/*/extract/bootoracle
games/*/extract/webexport
games/*/extract/oracleshot
games/*/extract/spriterip
games/*/extract/ndsextract
games/*/extract/exportglb
games/*/extract/trackmap
games/*/extract/rendermodel
games/*/extract/rendertex
games/*/extract/modeldump
games/*/extract/placeshot
games/*/extract/objsettle
games/*/extract/spawncheck

# --- regenerable extraction output (dev-only) ---
games/*/extracted/
games/*/work/
games/*/extract/unpacked/
games/*/extract/decode
games/*/extract/unpack
games/*/extract/runlauncher
